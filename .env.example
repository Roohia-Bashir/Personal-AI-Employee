# ============================================================================
# Personal AI Employee - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control (already in .gitignore)

# ── Vault Configuration ─────────────────────────────────────────────────────
# Path to your Obsidian vault (where all data is stored)
VAULT_PATH=./AI_Employee_Vault

# Drop folder for file-based triggers
DROP_FOLDER_PATH=./drop_folder

# ── Gmail Configuration ─────────────────────────────────────────────────────
# Path to Gmail API credentials (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./credentials.json

# Path where Gmail OAuth token will be stored (auto-generated on first run)
GMAIL_TOKEN_PATH=./watchers/token.pickle

# How often to check Gmail (in seconds)
CHECK_INTERVAL=120

# ── WhatsApp Configuration ──────────────────────────────────────────────────
# Path where WhatsApp Web session will be stored
WHATSAPP_SESSION_PATH=./.whatsapp_session

# How often to check WhatsApp (in seconds)
WHATSAPP_CHECK_INTERVAL=30

# ── LinkedIn Configuration ──────────────────────────────────────────────────
# Path where LinkedIn session will be stored
LINKEDIN_SESSION_PATH=./.linkedin_session

# How often to check LinkedIn queue (in seconds)
LINKEDIN_CHECK_INTERVAL=300

# ── Twitter Configuration ───────────────────────────────────────────────────
# Path where Twitter session cookies will be stored
TWITTER_SESSION_PATH=./.twitter_session

# How often to check Twitter queue (in seconds)
TWITTER_CHECK_INTERVAL=300

# ── Facebook Configuration ──────────────────────────────────────────────────
# Path where Facebook session cookies will be stored
FACEBOOK_SESSION_PATH=./.facebook_session

# How often to check Facebook queue (in seconds)
FACEBOOK_CHECK_INTERVAL=300

# ── Odoo ERP Configuration (Optional - Gold Tier) ───────────────────────────
# Only needed if you want accounting/invoicing integration
# ODOO_URL=https://your-odoo-instance.com
# ODOO_DB=your_database_name
# ODOO_USERNAME=your_username
# ODOO_PASSWORD=your_password

# ── Google Calendar Configuration (Optional - Gold Tier) ────────────────────
# Only needed if you want calendar integration
# GOOGLE_CALENDAR_CREDENTIALS_PATH=./calendar_credentials.json
# GOOGLE_CALENDAR_TOKEN_PATH=./watchers/calendar_token.pickle

# ── Safety Configuration ────────────────────────────────────────────────────
# IMPORTANT: Keep this true until you've tested everything thoroughly
# When true, no real external actions will be taken (safe testing mode)
DRY_RUN=true

# ── Advanced Configuration ──────────────────────────────────────────────────
# Uncomment and modify these only if you know what you're doing

# Maximum retries for failed operations
# MAX_RETRIES=3

# Retry delay in seconds
# RETRY_DELAY=10

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================================
# Setup Instructions:
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Set DRY_RUN=true for initial testing
# 4. Run: uv run python main.py --dry-run
# 5. Once tested, set DRY_RUN=false for production use
#
# Security Notes:
# - Never commit .env to version control
# - Keep credentials secure and rotate regularly
# - Use separate test accounts during development
# - Review audit logs regularly in /Vault/Logs/
# ============================================================================
